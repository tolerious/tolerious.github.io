        <div class="book-cover" style="background: linear-gradient(135deg, #64748b 0%, #475569 100%);">
          <div class="book-title">More<br>Coming</div>
          <div class="book-language" style="background: rgba(255,255,255,0.1); color: #94a3b8;">即将推出</div>
        </div>
      </div>
      <div class="shelf-board"></div>
    </div>

    <!-- 第二层书架 -->
    <div class="shelf">
      <div class="book" style="opacity: 0.5; cursor: not-allowed;">
        <div class="book-spine">
          <div class="spine-ridge"></div>
        </div>
        <div class="book-cover" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
          <div class="book-title">Vue.js<br>Tutorial</div>
          <div class="book-language lang-zh">即将推出</div>
        </div>
      </div>
      <div class="book" style="opacity: 0.5; cursor: not-allowed;">
        <div class="book-spine">
          <div class="spine-ridge"></div>
        </div>
        <div class="book-cover" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
          <div class="book-title">React<br>Tutorial</div>
          <div class="book-language lang-zh">即将推出</div>
        </div>
      </div>
      <div class="book" style="opacity: 0.5; cursor: not-allowed;">
        <div class="book-spine">
          <div class="spine-ridge"></div>
        </div>
        <div class="book-cover" style="background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);">
          <div class="book-title">Type<br>Script</div>
          <div class="book-language lang-zh">即将推出</div>
        </div>
      </div>
      <div class="shelf-board"></div>
    </div>

    <!-- 第三层书架 -->
    <div class="shelf">
      <div class="book" style="opacity: 0.5; cursor: not-allowed;">
        <div class="book-spine">
          <div class="spine-ridge"></div>
        </div>
        <div class="book-cover" style="background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);">
          <div class="book-title">Next.js<br>Tutorial</div>
          <div class="book-language lang-zh">即将推出</div>
        </div>
      </div>
      <div class="book" style="opacity: 0.5; cursor: not-allowed;">
        <div class="book-spine">
          <div class="spine-ridge"></div>
        </div>
        <div class="book-cover" style="background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);">
          <div class="book-title">Node.js<br>Tutorial</div>
          <div class="book-language lang-zh">即将推出</div>
        </div>
      </div>
      <div class="book" style="opacity: 0.5; cursor: not-allowed;">
        <div class="book-spine">
          <div class="spine-ridge"></div>
        </div>
        <div class="book-cover" style="background: linear-gradient(135deg, #f43f5e 0%, #e11d48 100%);">
          <div class="book-title">Webpack<br>Guide</div>
